-- dist/ is generated by `darklua process src dist` before running these tests.
local T               = require("./helpers")
local TransformerModel = require("../../dist/components/TransformerModel")

local function smallConfig(overrides)
	local cfg = {
		dModel    = 8,
		numHeads  = 2,
		dFF       = 16,
		numLayers = 2,
		maxSeqLen = 16,
		vocabSize = 20,
	}
	if overrides then
		for k, v in pairs(overrides) do
			cfg[k] = v
		end
	end
	return cfg
end

-- ── Construction ─────────────────────────────────────────────────────────────
T.test("new: basic properties", function()
	local m = TransformerModel.new(smallConfig())
	T.eq(m.vocabSize, 20)
	T.eq(m.dModel,    8)
	T.eq(m.numLayers, 2)
end)

T.test("new: embedding weight shape is (vocabSize × dModel)", function()
	local m = TransformerModel.new(smallConfig())
	T.shape(m.embedding.weights, 20, 8)
end)

T.test("new: finalProj shape is (dModel × vocabSize)", function()
	local m = TransformerModel.new(smallConfig())
	T.shape(m.finalProj, 8, 20)
end)

T.test("new: weightTied=false by default", function()
	local m = TransformerModel.new(smallConfig())
	T.eq(m.weightTied, false)
end)

T.test("new: weightTying=true sets weightTied flag", function()
	local m = TransformerModel.new(smallConfig({ weightTying = true }))
	T.eq(m.weightTied, true)
end)

-- ── Weight tying ──────────────────────────────────────────────────────────────
T.test("weightTying: finalProj is transpose of embedding.weights", function()
	local m     = TransformerModel.new(smallConfig({ weightTying = true }))
	local embed = m.embedding.weights
	local proj  = m.finalProj
	-- proj should be (dModel × vocabSize) = transpose of embed (vocabSize × dModel)
	T.shape(proj, 8, 20)
	T.near(proj[1][1], embed[1][1], 1e-9, "proj[i][j] == embed[j][i]")
	T.near(proj[1][5], embed[5][1], 1e-9, "proj[i][j] == embed[j][i]")
end)

-- ── forward ───────────────────────────────────────────────────────────────────
T.test("forward: output shape is (seqLen × vocabSize)", function()
	local m   = TransformerModel.new(smallConfig())
	local out = m:forward({ 1, 2, 3, 4 })
	T.shape(out, 4, 20)
end)

T.test("forward: values are finite", function()
	local m   = TransformerModel.new(smallConfig())
	local out = m:forward({ 1, 5, 10, 15 })
	for i = 1, 4 do
		for j = 1, 20 do
			T.ok(out[i][j] == out[i][j], "NaN at " .. i .. "," .. j)
		end
	end
end)

T.test("forward: single token input works", function()
	local m   = TransformerModel.new(smallConfig())
	local out = m:forward({ 7 })
	T.shape(out, 1, 20)
end)

-- ── backward ─────────────────────────────────────────────────────────────────
T.test("backward: returns grad tables", function()
	local m   = TransformerModel.new(smallConfig())
	m:forward({ 1, 2, 3 })
	local zeros3x20 = {}
	for i = 1, 3 do
		zeros3x20[i] = {}
		for j = 1, 20 do
			zeros3x20[i][j] = 0.01
		end
	end
	local res = m:backward(zeros3x20)
	T.ok(res.gradEmbeddingWeights ~= nil)
	T.ok(res.gradFinalProj ~= nil)
end)

-- ── predictNextToken ─────────────────────────────────────────────────────────
T.test("predictNextToken: returns valid token id", function()
	local m  = TransformerModel.new(smallConfig())
	local id = m:predictNextToken({ 1, 2, 3 })
	T.ok(id >= 1 and id <= 20, "token id should be in [1, vocabSize]")
end)

T.test("predictNextTokenTemperature: valid with temp=1", function()
	local m  = TransformerModel.new(smallConfig())
	local id = m:predictNextTokenTemperature({ 1, 2 }, 1.0)
	T.ok(id >= 1 and id <= 20)
end)

T.test("predictNextTokenTemperature: temp=0 returns argmax", function()
	local m   = TransformerModel.new(smallConfig())
	local id1 = m:predictNextTokenTemperature({ 5, 6 }, 0)
	local id2 = m:predictNextTokenTemperature({ 5, 6 }, 0)
	T.eq(id1, id2, "greedy (temp=0) must be deterministic")
end)

-- ── Top-k sampling ───────────────────────────────────────────────────────────
T.test("predictNextTokenTopK: returns valid id", function()
	local m  = TransformerModel.new(smallConfig())
	local id = m:predictNextTokenTopK({ 1, 2, 3 }, 5, 1.0)
	T.ok(id >= 1 and id <= 20)
end)

T.test("predictNextTokenTopK: k=1 is deterministic", function()
	local m   = TransformerModel.new(smallConfig())
	local id1 = m:predictNextTokenTopK({ 3, 4 }, 1, 1.0)
	local id2 = m:predictNextTokenTopK({ 3, 4 }, 1, 1.0)
	T.eq(id1, id2, "top-1 should always pick the same token")
end)

-- ── Nucleus sampling ─────────────────────────────────────────────────────────
T.test("predictNextTokenNucleus: returns valid id", function()
	local m  = TransformerModel.new(smallConfig())
	local id = m:predictNextTokenNucleus({ 1, 2, 3 }, 0.9, 1.0)
	T.ok(id >= 1 and id <= 20)
end)

T.test("predictNextTokenNucleus: p=1.0 samples full distribution", function()
	local m  = TransformerModel.new(smallConfig())
	local id = m:predictNextTokenNucleus({ 7, 8 }, 1.0, 0.5)
	T.ok(id >= 1 and id <= 20)
end)

-- ── KV-cache forward ─────────────────────────────────────────────────────────
T.test("forwardCached: prompt fill shape matches forward", function()
	local m      = TransformerModel.new(smallConfig())
	local tokens = { 1, 2, 3, 4, 5 }
	local reg    = m:forward(tokens)
	m:clearKVCache()
	local cached = m:forwardCached(tokens, 1)
	T.shape(cached, #tokens, 20)
	T.shape(reg,    #tokens, 20)
end)

T.test("forwardCached: incremental single-token output is finite", function()
	local m = TransformerModel.new(smallConfig())
	m:clearKVCache()
	m:forwardCached({ 1, 2, 3 }, 1)
	local out = m:forwardCached({ 4 }, 4)
	T.shape(out, 1, 20)
	for j = 1, 20 do
		T.ok(out[1][j] == out[1][j], "NaN in incremental step")
	end
end)

T.test("clearKVCache: resets then re-runs correctly", function()
	local m = TransformerModel.new(smallConfig())
	m:clearKVCache()
	m:forwardCached({ 1, 2, 3 }, 1)
	m:clearKVCache()
	local out = m:forwardCached({ 1, 2, 3 }, 1)
	T.shape(out, 3, 20)
end)

print(T.report("TransformerModel"))
if T._failed > 0 then
	error(T._failed .. " test(s) failed in TransformerModel")
end
