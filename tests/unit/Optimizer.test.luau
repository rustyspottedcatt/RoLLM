-- dist/ is generated by `darklua process src dist` before running these tests.
local T         = require("./helpers")
local Optimizer = require("../../dist/lib/Optimizer")

-- ── Construction ─────────────────────────────────────────────────────────────
T.test("new: stores learning rate", function()
	local opt = Optimizer.new(0.001)
	T.near(opt.learningRate, 0.001)
end)

T.test("new: default Adam hyperparams", function()
	local opt = Optimizer.new(0.01)
	T.near(opt.beta1, 0.9)
	T.near(opt.beta2, 0.999)
	T.ok(opt.epsilon > 0)
end)

-- ── updateParameters (matrix) ────────────────────────────────────────────────
T.test("updateParameters matrix: moves weights in gradient direction", function()
	local opt     = Optimizer.new(0.1)
	local weights = { { 1.0, 2.0 }, { 3.0, 4.0 } }
	opt:updateParameters({
		w = { value = weights, grad = { { 0.5, 0.5 }, { 0.5, 0.5 } } },
	})
	T.ok(weights[1][1] < 1.0, "weight should decrease with positive gradient")
	T.ok(weights[2][2] < 4.0, "weight should decrease with positive gradient")
end)

T.test("updateParameters matrix: negative gradient increases weight", function()
	local opt     = Optimizer.new(0.1)
	local weights = { { 1.0, 2.0 }, { 3.0, 4.0 } }
	opt:updateParameters({
		w = { value = weights, grad = { { -0.5, -0.5 }, { -0.5, -0.5 } } },
	})
	T.ok(weights[1][1] > 1.0, "weight should increase with negative gradient")
end)

T.test("updateParameters matrix: returns update count", function()
	local opt    = Optimizer.new(0.01)
	local n      = opt:updateParameters({
		a = { value = { { 1, 2 }, { 3, 4 } }, grad = { { 0, 0 }, { 0, 0 } } },
	})
	T.eq(n, 4)
end)

-- ── updateParameters (vector) ────────────────────────────────────────────────
T.test("updateParameters vector: values change", function()
	local opt = Optimizer.new(0.1)
	local v   = { 1.0, 2.0, 3.0 }
	opt:updateParameters({ v = { value = v, grad = { 0.5, 0.5, 0.5 } } })
	T.ok(v[1] < 1.0)
	T.ok(v[3] < 3.0)
end)

T.test("updateParameters vector: returns count", function()
	local opt = Optimizer.new(0.01)
	local n   = opt:updateParameters({
		v = { value = { 0, 0, 0 }, grad = { 0, 0, 0 } },
	})
	T.eq(n, 3)
end)

-- ── LR override ──────────────────────────────────────────────────────────────
T.test("updateParameters: learningRate override smaller → smaller step", function()
	local big      = { { 1.0 } }
	local small    = { { 1.0 } }
	local bigOpt   = Optimizer.new(0.1)
	local smallOpt = Optimizer.new(0.1)
	bigOpt:updateParameters({ w = { value = big,  grad = { { 1.0 } } } }, 0.5)
	smallOpt:updateParameters({ w = { value = small, grad = { { 1.0 } } } }, 0.01)
	T.ok(math.abs(1.0 - big[1][1]) > math.abs(1.0 - small[1][1]),
		"larger LR should produce larger step")
end)

-- ── clipGradNorm ─────────────────────────────────────────────────────────────
T.test("clipGradNorm: norm below maxNorm leaves grads unchanged", function()
	local opt    = Optimizer.new(0.01)
	local params = {
		w = { value = { { 0 } }, grad = { { 0.1 } } },
	}
	opt:clipGradNorm(params, 10.0)
	T.near(params.w.grad[1][1], 0.1, 1e-6, "grad should be unchanged when below clip")
end)

T.test("clipGradNorm: large gradient is clipped", function()
	local opt    = Optimizer.new(0.01)
	local params = {
		w = { value = { { 0, 0 } }, grad = { { 1000.0, 1000.0 } } },
	}
	opt:clipGradNorm(params, 1.0)
	local norm = math.sqrt(params.w.grad[1][1] ^ 2 + params.w.grad[1][2] ^ 2)
	T.near(norm, 1.0, 1e-5, "gradient norm should be clipped to maxNorm")
end)

T.test("clipGradNorm: zero gradient is safe", function()
	local opt    = Optimizer.new(0.01)
	local params = { w = { value = { { 0 } }, grad = { { 0.0 } } } }
	opt:clipGradNorm(params, 1.0)
	T.near(params.w.grad[1][1], 0.0)
end)

-- ── getLR ────────────────────────────────────────────────────────────────────
T.test("getLR: warmup epoch 1 gives very small LR", function()
	local opt = Optimizer.new(1.0)
	local lr  = opt:getLR(1, 100, 1.0, 10)
	T.ok(lr < 0.5, "first warmup epoch should have small LR")
end)

T.test("getLR: after warmup gives ~baseLR", function()
	local opt = Optimizer.new(1.0)
	local lr  = opt:getLR(10, 100, 1.0, 10)
	T.near(lr, 1.0, 0.01, "end of warmup should be ~baseLR")
end)

T.test("getLR: final epoch gives small LR (cosine decay)", function()
	local opt = Optimizer.new(1.0)
	local lr  = opt:getLR(100, 100, 1.0, 10)
	T.ok(lr < 0.15, "end of cosine decay should be small")
end)

T.test("getLR: no warmup (nil) uses full cosine from epoch 1", function()
	local opt = Optimizer.new(1.0)
	local lr  = opt:getLR(1, 100, 1.0, nil)
	T.ok(lr > 0, "should return positive LR without warmup")
end)

print(T.report("Optimizer"))
if T._failed > 0 then
	error(T._failed .. " test(s) failed in Optimizer")
end
