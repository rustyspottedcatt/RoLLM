-- dist/ is generated by `darklua process src dist` before running these tests.
local T   = require("./helpers")
local MHA = require("../../dist/components/MultiHeadAttention")

local D_MODEL  = 8
local N_HEADS  = 2
local SEQ_LEN  = 5

local function makeSeq(seqLen, dModel, val)
	val = val or 0.1
	local m = {}
	for i = 1, seqLen do
		m[i] = {}
		for j = 1, dModel do
			m[i][j] = val + (i * 0.03 + j * 0.01)
		end
	end
	return m
end

local function causalMask(n)
	local mask = {}
	for i = 1, n do
		mask[i] = {}
		for j = 1, n do
			mask[i][j] = if j > i then -1e9 else 0
		end
	end
	return mask
end

-- ── Construction ─────────────────────────────────────────────────────────────
T.test("new: Wq shape is (dModel × dModel)", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	T.shape(mha.Wq, D_MODEL, D_MODEL)
end)

T.test("new: Wk/Wv/Wo same shape as Wq", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	T.shape(mha.Wk, D_MODEL, D_MODEL)
	T.shape(mha.Wv, D_MODEL, D_MODEL)
	T.shape(mha.Wo, D_MODEL, D_MODEL)
end)

T.test("new: headDim = dModel / numHeads", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	T.eq(mha.headDim, D_MODEL // N_HEADS)
end)

T.test("new: dModel not divisible by numHeads throws", function()
	T.throws(function()
		MHA.new(7, 2)
	end, "non-divisible dModel/numHeads should throw")
end)

-- ── forward ───────────────────────────────────────────────────────────────────
T.test("forward: output shape is (seqLen × dModel)", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	local x   = makeSeq(SEQ_LEN, D_MODEL)
	local out = mha:forward(x, nil)
	T.shape(out, SEQ_LEN, D_MODEL)
end)

T.test("forward: output is finite", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	local x   = makeSeq(SEQ_LEN, D_MODEL)
	local out = mha:forward(x, nil)
	for i = 1, SEQ_LEN do
		for j = 1, D_MODEL do
			T.ok(out[i][j] == out[i][j], "NaN at " .. i .. "," .. j)
		end
	end
end)

T.test("forward: causal mask does not change shape", function()
	local mha  = MHA.new(D_MODEL, N_HEADS)
	local x    = makeSeq(SEQ_LEN, D_MODEL)
	local mask = causalMask(SEQ_LEN)
	local out  = mha:forward(x, mask)
	T.shape(out, SEQ_LEN, D_MODEL)
end)

T.test("forward: single-token input works", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	local x   = makeSeq(1, D_MODEL)
	local out = mha:forward(x, nil)
	T.shape(out, 1, D_MODEL)
end)

-- ── backward ─────────────────────────────────────────────────────────────────
T.test("backward: grad shape is (seqLen × dModel)", function()
	local mha     = MHA.new(D_MODEL, N_HEADS)
	local x       = makeSeq(SEQ_LEN, D_MODEL)
	mha:forward(x, nil)
	local gradOut = makeSeq(SEQ_LEN, D_MODEL, 0.05)
	local gradIn  = mha:backward(gradOut)
	T.shape(gradIn, SEQ_LEN, D_MODEL)
end)

T.test("backward: gradWq is populated", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	local x   = makeSeq(SEQ_LEN, D_MODEL)
	mha:forward(x, nil)
	mha:backward(makeSeq(SEQ_LEN, D_MODEL, 0.05))
	T.ok(mha.gradWq ~= nil, "gradWq should exist after backward")
end)

-- ── KV cache ─────────────────────────────────────────────────────────────────
T.test("forwardCached: single-token shape is (1 × dModel)", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	mha:clearKVCache()
	local out = mha:forwardCached(makeSeq(1, D_MODEL), nil)
	T.shape(out, 1, D_MODEL)
end)

T.test("forwardCached: prompt fill shape matches seqLen", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	mha:clearKVCache()
	local out = mha:forwardCached(makeSeq(SEQ_LEN, D_MODEL), causalMask(SEQ_LEN))
	T.shape(out, SEQ_LEN, D_MODEL)
end)

T.test("clearKVCache: resets accumulated K/V state", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	mha:clearKVCache()
	mha:forwardCached(makeSeq(3, D_MODEL), causalMask(3))
	mha:clearKVCache()
	-- After clearing, running a single-token forward should be equivalent to fresh state
	local out = mha:forwardCached(makeSeq(1, D_MODEL), nil)
	T.shape(out, 1, D_MODEL)
end)

T.test("forwardCached: multi-step generation stays finite", function()
	local mha = MHA.new(D_MODEL, N_HEADS)
	mha:clearKVCache()
	mha:forwardCached(makeSeq(SEQ_LEN, D_MODEL), causalMask(SEQ_LEN))
	for _ = 1, 5 do
		local out = mha:forwardCached(makeSeq(1, D_MODEL, 0.2), nil)
		for j = 1, D_MODEL do
			T.ok(out[1][j] == out[1][j], "NaN detected during incremental generation")
		end
	end
end)

print(T.report("MultiHeadAttention"))
if T._failed > 0 then
	error(T._failed .. " test(s) failed in MultiHeadAttention")
end
