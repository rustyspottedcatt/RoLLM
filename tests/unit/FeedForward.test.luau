-- dist/ is generated by `darklua process src dist` before running these tests.
local T          = require("./helpers")
local FeedForward = require("../../dist/components/FeedForward")

local D_MODEL = 8
local D_FF    = 16
local SEQ_LEN = 4

local function makeInput(rows, cols, val)
	val = val or 0.5
	local m = {}
	for i = 1, rows do
		m[i] = {}
		for j = 1, cols do
			m[i][j] = val + (i + j) * 0.01
		end
	end
	return m
end

-- ── Construction ─────────────────────────────────────────────────────────────
T.test("new: W1 shape is (dModel × dFF)", function()
	local ff = FeedForward.new(D_MODEL, D_FF)
	T.shape(ff.W1, D_MODEL, D_FF)
end)

T.test("new: W2 shape is (dFF × dModel)", function()
	local ff = FeedForward.new(D_MODEL, D_FF)
	T.shape(ff.W2, D_FF, D_MODEL)
end)

T.test("new: bias b1 has dFF elements", function()
	local ff = FeedForward.new(D_MODEL, D_FF)
	T.len(ff.b1, D_FF)
end)

T.test("new: bias b2 has dModel elements", function()
	local ff = FeedForward.new(D_MODEL, D_FF)
	T.len(ff.b2, D_MODEL)
end)

-- ── forward ───────────────────────────────────────────────────────────────────
T.test("forward: output shape is (seqLen × dModel)", function()
	local ff  = FeedForward.new(D_MODEL, D_FF)
	local x   = makeInput(SEQ_LEN, D_MODEL)
	local out = ff:forward(x)
	T.shape(out, SEQ_LEN, D_MODEL)
end)

T.test("forward: values are finite (no NaN/inf)", function()
	local ff  = FeedForward.new(D_MODEL, D_FF)
	local x   = makeInput(SEQ_LEN, D_MODEL)
	local out = ff:forward(x)
	for i = 1, SEQ_LEN do
		for j = 1, D_MODEL do
			T.ok(out[i][j] == out[i][j], "NaN detected at " .. i .. "," .. j)
			T.ok(math.abs(out[i][j]) < 1e10, "inf-like value at " .. i .. "," .. j)
		end
	end
end)

T.test("forward: deterministic (same input → same output)", function()
	local ff   = FeedForward.new(D_MODEL, D_FF)
	local x    = makeInput(SEQ_LEN, D_MODEL)
	local out1 = ff:forward(x)
	local out2 = ff:forward(x)
	for i = 1, SEQ_LEN do
		for j = 1, D_MODEL do
			T.near(out1[i][j], out2[i][j], 1e-9, "should be deterministic")
		end
	end
end)

-- ── GELU behaviour ───────────────────────────────────────────────────────────
T.test("GELU: output for large positive input is positive", function()
	-- Passing a bias-only forward with no weight contribution.
	-- Force all activations positive by setting a large constant input.
	local ff = FeedForward.new(1, 1)
	for i = 1, 1 do
		for j = 1, 1 do
			ff.W1[i][j] = 1.0
			ff.W2[j][i] = 1.0
		end
	end
	ff.b1[1] = 0.0
	ff.b2[1] = 0.0
	local x   = { { 5.0 } }
	local out = ff:forward(x)
	T.ok(out[1][1] > 0, "GELU of large positive value should be positive")
end)

T.test("GELU: output for zero input is approximately 0", function()
	local ff = FeedForward.new(1, 1)
	for i = 1, 1 do
		for j = 1, 1 do
			ff.W1[i][j] = 1.0
			ff.W2[j][i] = 1.0
		end
	end
	ff.b1[1] = 0.0
	ff.b2[1] = 0.0
	local out = ff:forward({ { 0.0 } })
	T.near(out[1][1], 0.0, 0.1, "GELU(0) ≈ 0")
end)

-- ── backward ─────────────────────────────────────────────────────────────────
T.test("backward: grad shape is (seqLen × dModel)", function()
	local ff  = FeedForward.new(D_MODEL, D_FF)
	local x   = makeInput(SEQ_LEN, D_MODEL)
	ff:forward(x)
	local gradOut = makeInput(SEQ_LEN, D_MODEL, 0.1)
	local gradIn  = ff:backward(gradOut)
	T.shape(gradIn, SEQ_LEN, D_MODEL)
end)

T.test("backward: gradW1 is populated with non-zero values", function()
	local ff  = FeedForward.new(D_MODEL, D_FF)
	local x   = makeInput(SEQ_LEN, D_MODEL)
	ff:forward(x)
	ff:backward(makeInput(SEQ_LEN, D_MODEL, 0.1))
	T.ok(ff.gradW1 ~= nil, "gradW1 should be populated")
	local hasNonZero = false
	for i = 1, D_MODEL do
		for j = 1, D_FF do
			if math.abs((ff.gradW1 :: any)[i][j]) > 1e-9 then
				hasNonZero = true
				break
			end
		end
	end
	T.ok(hasNonZero, "gradW1 should have non-zero entries")
end)

T.test("backward: called without prior forward raises error", function()
	local ff2 = FeedForward.new(D_MODEL, D_FF)
	T.throws(function()
		ff2:backward(makeInput(SEQ_LEN, D_MODEL, 0.1))
	end, "backward without forward should throw")
end)

print(T.report("FeedForward"))
if T._failed > 0 then
	error(T._failed .. " test(s) failed in FeedForward")
end
