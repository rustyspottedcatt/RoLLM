-- dist/ is generated by `darklua process src dist` before running these tests.
local T             = require("./helpers")
local AdaptiveVocab = require("../../dist/lib/AdaptiveVocab")

-- Minimal stub tokenizer: maps each character to a unique integer id
-- (simulates a GPT-2 BPE tokenizer interface used by AdaptiveVocab)
local function makeStubTokenizer(vocabSize)
	vocabSize = vocabSize or 100
	local tok = {}
	function tok:getVocabSize()
		return vocabSize
	end
	function tok:textToTokens(text)
		local out = {}
		for i = 1, #text do
			local byte = string.byte(text, i)
			-- Map byte to [1, vocabSize], clamping if necessary
			table.insert(out, (byte % vocabSize) + 1)
		end
		return out
	end
	function tok:tokensToText(tokens)
		local chars = {}
		for _, id in ipairs(tokens) do
			local byte = ((id - 1) % 95) + 32 -- printable ASCII
			table.insert(chars, string.char(byte))
		end
		return table.concat(chars)
	end
	return tok
end

local corpus = {
	"hello world",
	"hello roblox",
	"roblox is fun",
	"fun and games",
}

-- ── Construction ─────────────────────────────────────────────────────────────
T.test("new: creates with maxVocab limit", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	T.ok(av ~= nil)
end)

-- ── buildFromCorpus ───────────────────────────────────────────────────────────
T.test("buildFromCorpus: vocab size ≤ maxVocab", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 30)
	av:buildFromCorpus(corpus)
	T.ok(av:getVocabSize() <= 30, "vocab should be capped at maxVocab")
end)

T.test("buildFromCorpus: vocab size > 0", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	T.ok(av:getVocabSize() > 0, "should have at least one token")
end)

T.test("buildFromCorpus: includes UNK token", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	T.ok(av.unkDenseId ~= nil and av.unkDenseId >= 1,
		"unkDenseId should be set and ≥ 1")
end)

T.test("buildFromCorpus: gptToDense populated", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	local count = 0
	for _ in pairs(av.gptToDense) do
		count += 1
	end
	T.ok(count > 0, "gptToDense should have entries")
end)

-- ── encode / decode round-trip ────────────────────────────────────────────────
T.test("encode: returns a non-empty table", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	local ids = av:encode("hello")
	T.ok(#ids > 0, "encode should return at least one token id")
end)

T.test("encode: all ids are in [1, vocabSize]", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	local vs  = av:getVocabSize()
	local ids = av:encode("hello world roblox")
	for _, id in ipairs(ids) do
		T.ok(id >= 1 and id <= vs, "id " .. id .. " out of range [1," .. vs .. "]")
	end
end)

T.test("encode: unknown text maps to unkDenseId", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 5)
	av:buildFromCorpus({ "aaa" })  -- tiny corpus → most tokens will be OOV
	local ids = av:encode("zzzzzzzzzzz")
	for _, id in ipairs(ids) do
		T.ok(id == av.unkDenseId or (id >= 1 and id <= av:getVocabSize()),
			"OOV token should map to unkDenseId or be in vocab")
	end
end)

T.test("decode: returns a string", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	local ids    = av:encode("hello")
	local result = av:decode(ids)
	T.ok(type(result) == "string", "decode should return a string")
end)

T.test("decode: known token round-trips correctly", function()
	local tok = makeStubTokenizer(200)
	local av  = AdaptiveVocab.new(tok, 50)
	av:buildFromCorpus(corpus)
	-- Find a dense id for a token we know exists (gptToDense has at least one entry)
	local someDenseId = nil
	for _, denseId in pairs(av.gptToDense) do
		someDenseId = denseId
		break
	end
	T.ok(someDenseId ~= nil)
	local decoded = av:decode({ someDenseId })
	T.ok(type(decoded) == "string", "decode of known token should be a string")
end)

print(T.report("AdaptiveVocab"))
if T._failed > 0 then
	error(T._failed .. " test(s) failed in AdaptiveVocab")
end
